# APL Go Storefront — Environment Variables
# Copy this file to .env.local and fill in the values

# Medusa Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=your_publishable_key_from_medusa_admin

# App URL (used for OG images, redirects, referral links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# PayPal Business — Pagos (Rule 8: usa credenciales de Sandbox en desarrollo)
# Obtén estas claves en: https://developer.paypal.com/dashboard/applications
# ---------------------------------------------------------------------------

# Client ID de tu app PayPal — seguro para exponer al cliente (NEXT_PUBLIC_)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AYour_sandbox_client_id_here

# Client Secret — SOLO servidor; nunca añadir prefijo NEXT_PUBLIC_
PAYPAL_CLIENT_SECRET=your_sandbox_client_secret_here

# Webhook ID — PayPal Dashboard → Webhooks → tu endpoint → copiar el ID
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# Entorno: "sandbox" para desarrollo, "live" para producción
PAYPAL_ENVIRONMENT=sandbox

# ---------------------------------------------------------------------------
# Sentry — Monitoreo de errores (https://sentry.io)
# 1. Crea cuenta en sentry.io → New Project → Next.js
# 2. Copia el DSN desde: Settings → Projects → <proyecto> → Client Keys
# 3. SENTRY_ORG y SENTRY_PROJECT se usan para subir source maps en build
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your_key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=aplgo-storefront
