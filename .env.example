# APL Go Storefront — Environment Variables
# Copy this file to .env.local and fill in the values

# Medusa Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_PUBLISHABLE_KEY=your_publishable_key_from_medusa_admin

# App URL (used for OG images, redirects, referral links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
